@model Empleado

<form method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <input asp-for="Nombre" class="form-control" placeholder="Nombre" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div>
        <input asp-for="Apellidos" class="form-control" placeholder="Apellidos" />
        <span asp-validation-for="Apellidos" class="text-danger"></span>
    </div>

    <div>
        <input asp-for="Departamento" class="form-control" placeholder="Departamento" />
        <span asp-validation-for="Departamento" class="text-danger"></span>
    </div>

    <div>
        <input asp-for="Salario" class="form-control" />
        <span asp-validation-for="Salario" class="text-danger"></span>
    </div>

    <div>
        <input asp-for="FechaIngreso" type="date" class="form-control" />
        <span asp-validation-for="FechaIngreso" class="text-danger"></span>
    </div>

    <div>
        <label>
            <input type="checkbox" asp-for="Activo" class="form-check-input" />
            Activo
        </label>
    </div>

    <button type="submit" class="btn btn-primary">Actualizar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}