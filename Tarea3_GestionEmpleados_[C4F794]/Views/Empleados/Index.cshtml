@model List<Empleado>

<div class="container mt-4">

    <h2 class="mb-3">Gestión de Empleados</h2>

    <form method="get" class="row mb-3">
        <div class="col-md-4">
            <input class="form-control" type="text" name="busqueda" value="@ViewBag.Busqueda" placeholder="Buscar por nombre o departamento" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary" type="submit">Buscar</button>
        </div>
        <div class="col-md-2">
            <a class="btn btn-success" asp-action="Create">Nuevo</a>
        </div>
    </form>

    <p><strong>Total:</strong> @ViewBag.Total</p>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Departamento</th>
                <th>Salario</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.NombreCompleto</td>
                    <td>@e.Departamento</td>
                    <td>₡ @e.Salario</td>
                    <td>
                        @if (e.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Dado de baja</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@e.Id">Editar</a>

                        <form asp-action="ToggleActivo" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@e.Id" />
                            <button class="btn btn-secondary btn-sm" type="submit">
                                @(e.Activo ? "Dar de baja" : "Activar")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between">
        <div>
            Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas
        </div>

        <div>
            @if (ViewBag.PaginaActual > 1)
            {
                <a class="btn btn-outline-primary btn-sm"
                       href="?pagina=@(ViewBag.PaginaActual - 1)&busqueda=@ViewBag.Busqueda">
                    Anterior
                </a>
            }

            @if (ViewBag.PaginaActual < ViewBag.TotalPaginas)
            {
                <a class="btn btn-outline-primary btn-sm"
                       href="?pagina=@(ViewBag.PaginaActual + 1)&busqueda=@ViewBag.Busqueda">
                    Siguiente
                </a>
            }
        </div>
    </div>

</div>